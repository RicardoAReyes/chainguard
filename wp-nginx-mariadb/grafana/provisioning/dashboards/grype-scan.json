            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "prometheus",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "grype_scan_total{image=\"prometheus\"}",
          "legendFormat": "Total CVEs",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
