            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
