{
  "uid": "grype-scan-report",
  "title": "Grype Security Scan Report",
  "description": "Container image vulnerability scan results from Grype via Chainguard images",
  "tags": ["security", "grype", "chainguard"],
  "schemaVersion": 40,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "wordpress-custom",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "grype_scan_total{image=\"wordpress\"}",
          "legendFormat": "Total CVEs",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "nginx",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
