        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "grafana",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "grype_scan_total{image=\"grafana\"}",
          "legendFormat": "Total CVEs",
          "instant": true,
